---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import { lifetimeDeal } from '~/data/pricingData';
import Hero from '~/components/widgets/Hero.astro';

const metadata = { 
  title: 'Pricing | Secure Your Elite Address.Makeup URL', 
  description: 'Professional makeup studio vanity URLs with zero monthly fees. Transform your Google Business Profile and Social Bio into a luxury portfolio.' 
};
---
<Layout metadata={metadata}>
  <HeroText 
    tagline="The Professional Standard"
    title="A Stunning Home for Your Artistry. Live in Hours." 
    subtitle="More than just a link—it's your studio's digital flagship. Own a beautiful vanity URL (address.makeup/yourname) that transforms your social bio and Google profile into a high-end experience."
  />

  <div class="-mt-16">
    <Pricing prices={[lifetimeDeal]} />
  </div>

  <Features3
    title="Elevate Every Touchpoint"
    subtitle="We bridge the gap between your hard work at the vanity and your presence online."
    columns={3}
    items={[
      { title: 'Social Bio Transformation', description: 'Ditch generic link tools. Your Address.Makeup URL provides a high-end experience that keeps clients focused on your glam portfolio.', icon: 'tabler:link' },
      { title: 'Google Business Authority', description: 'Replace generic links on your Google Profile with a dedicated studio homepage that creates a massive authority signal.', icon: 'tabler:brand-google' },
      { title: 'Detailed Service Menu', description: 'Present your service menu with boutique styling, detailing your bridal packages and editorial work beautifully.', icon: 'tabler:clipboard-list' },
      { title: 'Live Portfolio Sync', description: 'We pull your live Instagram feed directly onto your unique URL, ensuring your portfolio is always current without any effort.', icon: 'tabler:brand-instagram' },
      { title: 'One-Time License', description: 'No monthly subscriptions or "SaaS Taxes." Pay once and own your professional identity for life.', icon: 'tabler:coin' },
      { title: 'White-Glove Delivery', description: 'From setup to feed syncing, we handle the technical heavy lifting with guaranteed same-day delivery.', icon: 'tabler:headset' },
    ]}
  />

  <FAQs
    class="-mt-16 px-6"
    title="Pricing & Setup Questions"
    items={[
        { title: 'How does same-day setup work?', description: 'Secure your license, fill out our brief content form, and if received by 2PM EST, your site goes live before the business day ends.', icon: 'tabler:bolt' },
        { title: 'Can I use a custom .com?', description: 'Yes! We can manage your standalone domain (yourname.com) for just $15/year, handling all DNS and SSL setup for you.', icon: 'tabler:world' },
        { title: 'Is this a monthly fee?', description: 'No. Address.Makeup is a one-time investment for setup and boutique design. You never pay a monthly fee again.', icon: 'tabler:coin' },
    ]}
  >
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </FAQs>

  <Hero class="-mt-16">
    <Fragment slot="image">
      <img src="/images/testimonial-5.webp" alt="MUA reviewing feedback" class="mx-auto rounded-md w-full shadow-lg" loading="lazy" />
    </Fragment>
  </Hero>
</Layout>
